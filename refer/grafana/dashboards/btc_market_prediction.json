      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT k.close, k.close_time\n  FROM dashboard.futures_index_price_klines_${interval} AS k\n  WHERE k.close IS NOT NULL\n  ORDER BY k.close_time DESC\n  LIMIT 1\n), preferred_base AS (\n  SELECT k.close, k.close_time\n  FROM dashboard.futures_index_price_klines_${interval} AS k\n  CROSS JOIN latest\n  WHERE k.close_time <= latest.close_time - INTERVAL '24 hours'\n    AND k.close IS NOT NULL\n  ORDER BY k.close_time DESC\n  LIMIT 1\n), fallback_base AS (\n  SELECT k.close, k.close_time\n  FROM dashboard.futures_index_price_klines_${interval} AS k\n  CROSS JOIN latest\n  WHERE k.close_time >= latest.close_time - INTERVAL '24 hours'\n    AND k.close IS NOT NULL\n  ORDER BY k.close_time ASC\n  LIMIT 1\n), base AS (\n  SELECT * FROM preferred_base\n  UNION ALL\n  SELECT * FROM fallback_base\n  WHERE NOT EXISTS (SELECT 1 FROM preferred_base)\n)\nSELECT CASE WHEN base.close = 0 THEN NULL ELSE ((latest.close - base.close) / base.close) * 100 END AS change_24h\nFROM latest\nLEFT JOIN base ON TRUE;",
          "refId": "A"
        }
      ],
      "title": "24h Change",
      "type": "stat"
    },
