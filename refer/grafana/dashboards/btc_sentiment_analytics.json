      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n  SELECT word_frequency\n  FROM dashboard.sentiment_${sentiment_interval}\n  WHERE word_frequency IS NOT NULL\n  ORDER BY create_time DESC\n  LIMIT 1\n), words AS (\n  SELECT\n    word,\n    word_count::BIGINT AS value\n  FROM latest,\n  LATERAL jsonb_each_text(word_frequency) AS words(word, word_count)\n  WHERE word_count IS NOT NULL\n    AND word !~ '[0-9]'\n    AND word ~ '[[:alpha:]]'\n    AND (LENGTH(word) >= 3 OR word IN ('ai', 'uk', 'eu'))\n    AND word NOT IN ('able', 'actual', 'already', 'also', 'always', 'another', 'anyone', 'anything', 'around', 'back', 'based', 'become', 'believe', 'big', 'bit', 'bitcoin', 'btc', 'could', 'crypto', 'don', 'even', 'every', 'get', 'going', 'got', 'https', 'lot', 'make', 'many', 'might', 'much', 'now', 'one', 'people', 'real', 'really', 'see', 'since', 'someone', 'something', 'still', 'thing', 'things', 'think', 'time', 'use', 'want', 'way', 'will', 'would')\n)\nSELECT\n  word AS text,\n  value\nFROM words\nORDER BY value DESC, text\nLIMIT 50;",
          "refId": "A"
        }
      ],
      "title": "Wordcloud",
      "type": "magnesium-wordcloud-panel"
    }
