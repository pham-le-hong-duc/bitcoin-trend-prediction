APP_IMAGE=docker.io/huynhngochoa212/thesis-pipeline:latest

# Public endpoint
PUBLIC_DOMAIN=btc.example.com
ACME_EMAIL=toilahoadeptraine@gmail.com

# Host paths on the VM
DATA_ROOT=/srv/bitcoin-trend-prediction
SEED_DATA_DIR=/srv/bitcoin-trend-prediction/seed-data

# Core services
TZ=UTC
SYMBOL=BTCUSDT
TIMESCALE_DB=base
TIMESCALE_USER=admin
TIMESCALE_PASSWORD=change-timescaledb-password
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-minio-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-grafana-password
GRAFANA_ANONYMOUS_ENABLED=false

# Private loopback-only ports for SSH tunneling
REDPANDA_LOCAL_PORT=9092
TIMESCALE_LOCAL_PORT=5433
MINIO_API_LOCAL_PORT=9000
MINIO_CONSOLE_LOCAL_PORT=9001
REDPANDA_CONSOLE_LOCAL_PORT=8081
AIRFLOW_LOCAL_PORT=8082

# Airflow profile is optional. Keep it off unless you need DAG execution.
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=change-airflow-db-password
AIRFLOW_DB_NAME=airflow
AIRFLOW_FERNET_KEY=replace-with-a-real-fernet-key
AIRFLOW_WEBSERVER_SECRET_KEY=replace-with-a-real-secret-key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_FIRSTNAME=Airflow
AIRFLOW_ADMIN_LASTNAME=Admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_PASSWORD=change-airflow-admin-password

# Dashboard consumer behavior
TIMESCALEDB_KAFKA_AUTO_OFFSET_RESET=latest
TIMESCALEDB_KAFKA_MIN_WARMUP_MESSAGES=500

# Optional Reddit profile
REDDIT_MODEL_DIR=/srv/bitcoin-trend-prediction/reddit-models
REDDIT_COOKIES_DIR=/srv/bitcoin-trend-prediction/reddit-cookies
REDDIT_PROXY=
REDDIT_MODEL_BATCH_SIZE=32
REDDIT_MAX_SUBMISSIONS_PER_RUN=50
REDDIT_MAX_COMMENT_SUBMISSIONS_PER_RUN=20
REDDIT_MAX_COMMENTS_PER_RUN=1000
REDDIT_MAX_TRACKING_LOOPS_PER_RUN=1
